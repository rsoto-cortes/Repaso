  <property name="styleSheet">
   <string notr="true">/* Estilo general del diálogo */
QDialog {
    background-color: #f9f9f9;
    border: 1px solid #dcdcdc;
    border-radius: 8px;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 14px;
    color: #333333;
}

/* Etiquetas */
QLabel {
    color: #444444;
    font-weight: bold;
    padding: 4px;
}

/* Campos de texto */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #cccccc;
    border-radius: 4px;
    padding: 6px;
    font-size: 13px;
    selection-background-color: #0078d7; /* Azul profesional */
    selection-color: #ffffff;
}

QLineEdit:focus {
    border: 1px solid #0078d7;
    box-shadow: 0 0 4px rgba(0, 120, 215, 0.5);
}

/* Botones */
QPushButton {
    background-color: #0078d7;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #005a9e;
}

QPushButton:pressed {
    background-color: #004578;
}

/* Botón deshabilitado */
QPushButton:disabled {
    background-color: #cccccc;
    color: #666666;
}
</string>
