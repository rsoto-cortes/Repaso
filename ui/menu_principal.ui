  <property name="styleSheet">
   <string notr="true">/* Estilo general para la ventana principal */
QMainWindow {
    background-color: #f9f9f9;   /* Fondo claro y limpio */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 16px;
    color: #333333;              /* Texto gris oscuro para buena legibilidad */
}

/* Barra de menús */
QMenuBar {
    background-color: #ffffff;
    font-size: 16px;
    color: #333333;
    border-bottom: 1px solid #dcdcdc;
}

QMenuBar::item {
    background: transparent;
    padding: 6px 12px;
}

QMenuBar::item:selected {
    background: #e6f0ff;         /* Azul muy claro al pasar el cursor */
    color: #1a73e8;              /* Azul profesional */
}

/* Menús desplegables */
QMenu {
    background-color: #ffffff;
    border: 1px solid #dcdcdc;
    font-size: 16px;
    color: #333333;
}

QMenu::item {
    padding: 6px 20px;
}

QMenu::item:selected {
    background-color: #e6f0ff;
    color: #1a73e8;
}

/* Acciones (QAction se estiliza a través de QMenu/QMenuBar) */
QAction {
    font-size: 16px;
    color: #333333;
}

/* Barra de estado */
QStatusBar {
    background-color: #f1f1f1;
    font-size: 16px;
    color: #333333;
    border-top: 1px solid #dcdcdc;
}

QStatusBar::item {
    border: none;
    padding: 4px 8px;
}
</string>
